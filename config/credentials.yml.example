# =============================================================================
# credentials.yml.example
# =============================================================================
# Copy this file to credentials.yml and fill in your API key.
# IMPORTANT: never commit credentials.yml to version control.
# Add it to .gitignore:
#   echo "config/credentials.yml" >> .gitignore
#
# Only one credential is required:
#   OpenTopography API key — free registration at https://opentopography.org/
#
# Landsat imagery is downloaded from Microsoft Planetary Computer (free,
# anonymous, no account required).
# OSM data is downloaded via osmextract / Overpass API (free, no account).
# =============================================================================

opentopography:
  api_key: "YOUR_OPENTOPOGRAPHY_API_KEY"
